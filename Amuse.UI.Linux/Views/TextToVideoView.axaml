<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Amuse.UI.Linux.ViewModels"
             xmlns:ia="using:Projektanker.Icons.Avalonia"
             x:Class="Amuse.UI.Linux.Views.TextToVideoView"
             x:DataType="vm:TextToVideoViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Slider">
            <Setter Property="Foreground" Value="#4FC3F7"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#1976D2"/>
        </Style>
        <Style Selector="Button.Primary:disabled">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#555555"/>
        </Style>
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
        </Style>
        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#7f1111"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="320,*">

        <!-- ===== LEFT PANEL: Settings ===== -->
        <Border Grid.Column="0"
                Background="#141414"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Generate / Cancel button -->
                <Grid DockPanel.Dock="Bottom" Margin="12,8">
                    <Button Classes="Primary"
                            Content="Generate Video"
                            Command="{Binding GenerateCommand}"
                            HorizontalAlignment="Stretch"
                            IsVisible="{Binding !IsGenerating}"/>
                    <Button Classes="Danger"
                            Command="{Binding CancelCommand}"
                            HorizontalAlignment="Stretch"
                            IsVisible="{Binding IsGenerating}">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <ia:Icon Value="fa-stop" FontSize="13"/>
                            <TextBlock Text="Cancel" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Deps banner -->
                <Border DockPanel.Dock="Top" Background="#1A2A1A" BorderBrush="#2E4D2E"
                        BorderThickness="0,0,0,1" Padding="12,8" IsVisible="{Binding HasDeps}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ia:Icon Value="fa-circle-check" FontSize="13" Foreground="#4CAF50"/>
                        <TextBlock Text="{Binding DepsStatus}" FontSize="12" Foreground="#88BB88"/>
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Top" Background="#2A1A1A" BorderBrush="#4D2E2E"
                        BorderThickness="0,0,0,1" Padding="12,10" IsVisible="{Binding !HasDeps}">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ia:Icon Value="fa-triangle-exclamation" FontSize="13" Foreground="#FFA726"/>
                            <TextBlock Text="{Binding DepsStatus}" FontSize="12" Foreground="#FFAA66" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Classes="Secondary" Content="Install Dependencies"
                                Command="{Binding InstallDepsCommand}"
                                IsEnabled="{Binding !IsInstalling}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Settings -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,8,12,12" Spacing="0">

                        <!-- Model -->
                        <TextBlock Text="MODEL" Classes="Label"/>
                        <ComboBox ItemsSource="{Binding ModelPresets}"
                                  SelectedValueBinding="{Binding ModelId}"
                                  SelectedValue="{Binding SelectedModel}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:VideoModelPreset">
                                    <TextBlock Text="{Binding Label}" FontSize="12"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox Text="{Binding SelectedModel}"
                                 Watermark="HuggingFace model ID"
                                 Margin="0,4,0,0"/>

                        <!-- Prompt -->
                        <Grid Margin="0,10,0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PROMPT"
                                       FontSize="11" Foreground="#888888"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Click="OnPastePromptClick"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="4,0" ToolTip.Tip="Paste prompt from clipboard">
                                <ia:Icon Value="fa-paste" FontSize="11" Foreground="#555555"/>
                            </Button>
                        </Grid>
                        <TextBox Text="{Binding Prompt}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="100"
                                 Watermark="Describe the video you want to generate…"/>

                        <!-- Frames -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FRAMES" Classes="Label" Margin="0"/>
                            <TextBlock Grid.Column="1" Text="{Binding NumFrames}"
                                       FontSize="13" Foreground="#4FC3F7" VerticalAlignment="Center"/>
                        </Grid>
                        <Slider Value="{Binding NumFrames}" Minimum="8" Maximum="32"
                                TickFrequency="8" IsSnapToTickEnabled="True"/>

                        <!-- FPS -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FPS" Classes="Label" Margin="0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Fps}"
                                       FontSize="13" Foreground="#4FC3F7" VerticalAlignment="Center"/>
                        </Grid>
                        <Slider Value="{Binding Fps}" Minimum="4" Maximum="16"
                                TickFrequency="4" IsSnapToTickEnabled="True"/>

                        <!-- Steps -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="STEPS" Classes="Label" Margin="0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Steps}"
                                       FontSize="13" Foreground="#4FC3F7" VerticalAlignment="Center"/>
                        </Grid>
                        <Slider Value="{Binding Steps}" Minimum="10" Maximum="50"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>

                        <!-- CPU warning -->
                        <Border Margin="0,12,0,0" Background="#1A1A00" BorderBrush="#3D3D00"
                                BorderThickness="1" CornerRadius="4" Padding="10,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ia:Icon Value="fa-clock" FontSize="12" Foreground="#CCCC00"/>
                                <TextBlock Text="CPU-only: video generation may take 30–120 min"
                                           FontSize="11" Foreground="#AAAA55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Install log -->
                        <Border Margin="0,12,0,0" IsVisible="{Binding IsInstalling}"
                                Background="#111" CornerRadius="4" Padding="8">
                            <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding InstallLog}" FontFamily="Monospace"
                                           FontSize="11" Foreground="#88BB88" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== RIGHT PANEL: Output ===== -->
        <Grid Grid.Column="1" Background="#1A1A1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Status bar -->
            <Border Grid.Row="0" Background="#111111" BorderBrush="#2A2A2A"
                    BorderThickness="0,0,0,1" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                                     Width="200" Height="4" Foreground="#4FC3F7" Background="#2A2A2A"
                                     IsVisible="{Binding IsGenerating}"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeElapsed}" FontSize="12" Foreground="#555555" VerticalAlignment="Center"
                                   IsVisible="{Binding TimeElapsed, Converter={x:Static vm:StringNotEmptyConverter.Instance}}"/>
                    </StackPanel>
                    <!-- Action buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                IsVisible="{Binding LastOutputPath, Converter={x:Static vm:NotNullConverter.Instance}}">
                        <Button Classes="Secondary" Command="{Binding OpenVideoCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <ia:Icon Value="fa-play" FontSize="12"/>
                                <TextBlock Text="Open GIF"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="Secondary" Command="{Binding SaveVideoCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <ia:Icon Value="fa-floppy-disk" FontSize="12"/>
                                <TextBlock Text="Save"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Preview area -->
            <Grid Grid.Row="1">

                <!-- Placeholder -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12"
                            IsVisible="{Binding PreviewFrame, Converter={x:Static vm:NullConverter.Instance}}">
                    <ia:Icon Value="fa-film" FontSize="64" Foreground="#2A2A2A"/>
                    <TextBlock Text="Generated video preview will appear here"
                               FontSize="14" Foreground="#444444" HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter a prompt and click Generate Video"
                               FontSize="12" Foreground="#333333" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- First frame preview -->
                <Border IsVisible="{Binding PreviewFrame, Converter={x:Static vm:NotNullConverter.Instance}}"
                        Padding="20">
                    <Grid>
                        <Image Source="{Binding PreviewFrame}" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- GIF badge -->
                        <Border Background="#CC000000" CornerRadius="4" Padding="8,4"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ia:Icon Value="fa-film" FontSize="12" Foreground="#4FC3F7"/>
                                <TextBlock Text="GIF — click Open to play" FontSize="11" Foreground="#AAAAAA"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Generating overlay -->
                <Border IsVisible="{Binding IsGenerating}" Background="#88000000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                        <ia:Icon Value="fa-spinner" FontSize="40" Foreground="#4FC3F7"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="14" Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                        <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                                     Width="300" Height="6" Foreground="#4FC3F7" Background="#2A2A2A"/>
                        <TextBlock Text="{Binding TimeElapsed}" FontSize="12" Foreground="#666666" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>

    </Grid>
</UserControl>
