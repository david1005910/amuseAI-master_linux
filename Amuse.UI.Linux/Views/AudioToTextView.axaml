<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Amuse.UI.Linux.ViewModels"
             xmlns:ia="using:Projektanker.Icons.Avalonia"
             x:Class="Amuse.UI.Linux.Views.AudioToTextView"
             x:DataType="vm:AudioToTextViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.Label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#1976D2"/>
        </Style>
        <Style Selector="Button.Primary:disabled">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#555555"/>
        </Style>
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
        </Style>
        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#7f1111"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.FileSelect">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style Selector="Button.FileSelect:pointerover">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#4FC3F7"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="320,*">

        <!-- ===== LEFT PANEL: Settings ===== -->
        <Border Grid.Column="0" Background="#141414" BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Transcribe / Cancel -->
                <Grid DockPanel.Dock="Bottom" Margin="12,8">
                    <Button Classes="Primary"
                            Content="Transcribe"
                            Command="{Binding TranscribeCommand}"
                            HorizontalAlignment="Stretch"
                            IsVisible="{Binding !IsTranscribing}"/>
                    <Button Classes="Danger"
                            Command="{Binding CancelCommand}"
                            HorizontalAlignment="Stretch"
                            IsVisible="{Binding IsTranscribing}">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <ia:Icon Value="fa-stop" FontSize="13"/>
                            <TextBlock Text="Cancel" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Deps banner -->
                <Border DockPanel.Dock="Top" Background="#1A2A1A" BorderBrush="#2E4D2E"
                        BorderThickness="0,0,0,1" Padding="12,8" IsVisible="{Binding HasDeps}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ia:Icon Value="fa-circle-check" FontSize="13" Foreground="#4CAF50"/>
                        <TextBlock Text="{Binding DepsStatus}" FontSize="12" Foreground="#88BB88"/>
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Top" Background="#2A1A1A" BorderBrush="#4D2E2E"
                        BorderThickness="0,0,0,1" Padding="12,10" IsVisible="{Binding !HasDeps}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ia:Icon Value="fa-triangle-exclamation" FontSize="13" Foreground="#FFA726"/>
                        <TextBlock Text="{Binding DepsStatus}" FontSize="12" Foreground="#FFAA66" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Settings scroll -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,8,12,12" Spacing="0">

                        <!-- Audio file selector -->
                        <TextBlock Text="AUDIO FILE" Classes="Label"/>
                        <Button Classes="FileSelect"
                                Name="SelectFileButton"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ia:Icon Value="fa-folder-open" FontSize="13" Foreground="#4FC3F7"/>
                                <TextBlock FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding SelectedAudioPath,
                                               TargetNullValue='Click to select WAV / MP3 / FLAC…',
                                               FallbackValue='Click to select WAV / MP3 / FLAC…'}"/>
                            </StackPanel>
                        </Button>

                        <!-- Model -->
                        <TextBlock Text="MODEL" Classes="Label"/>
                        <ComboBox ItemsSource="{Binding ModelPresets}"
                                  SelectedValueBinding="{Binding ModelId}"
                                  SelectedValue="{Binding SelectedModel}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:WhisperModelPreset">
                                    <TextBlock Text="{Binding Label}" FontSize="12"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox Text="{Binding SelectedModel}"
                                 Watermark="HuggingFace model ID"
                                 Margin="0,4,0,0"/>

                        <!-- Language -->
                        <TextBlock Text="LANGUAGE" Classes="Label"/>
                        <ComboBox ItemsSource="{Binding Languages}"
                                  SelectedValueBinding="{Binding Code}"
                                  SelectedValue="{Binding SelectedLanguage}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LanguageOption">
                                    <TextBlock Text="{Binding Label}" FontSize="12"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== RIGHT PANEL: Output ===== -->
        <Grid Grid.Column="1" Background="#1A1A1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Status bar -->
            <Border Grid.Row="0" Background="#111111" BorderBrush="#2A2A2A"
                    BorderThickness="0,0,0,1" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                                     Width="200" Height="4" Foreground="#4FC3F7" Background="#2A2A2A"
                                     IsVisible="{Binding IsTranscribing}"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeElapsed}" FontSize="12" Foreground="#555555" VerticalAlignment="Center"
                                   IsVisible="{Binding TimeElapsed, Converter={x:Static vm:StringNotEmptyConverter.Instance}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                IsVisible="{Binding TranscriptText, Converter={x:Static vm:NotNullConverter.Instance}}">
                        <Button Classes="Secondary" Command="{Binding CopyTextCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <ia:Icon Value="fa-copy" FontSize="12"/>
                                <TextBlock Text="Copy"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="Secondary" Command="{Binding SaveTranscriptCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <ia:Icon Value="fa-floppy-disk" FontSize="12"/>
                                <TextBlock Text="Save"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Transcript output -->
            <Grid Grid.Row="1">

                <!-- Placeholder -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12"
                            IsVisible="{Binding TranscriptText, Converter={x:Static vm:NullConverter.Instance}}">
                    <ia:Icon Value="fa-microphone" FontSize="64" Foreground="#2A2A2A"/>
                    <TextBlock Text="Transcription will appear here"
                               FontSize="14" Foreground="#444444" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select an audio file and click Transcribe"
                               FontSize="12" Foreground="#333333" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Transcript text -->
                <Border IsVisible="{Binding TranscriptText, Converter={x:Static vm:NotNullConverter.Instance}}"
                        Padding="24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding TranscriptText}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#DDDDDD"
                                 FontSize="15"
                                 LineHeight="24"/>
                    </ScrollViewer>
                </Border>

                <!-- Transcribing overlay -->
                <Border IsVisible="{Binding IsTranscribing}" Background="#88000000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                        <ia:Icon Value="fa-spinner" FontSize="40" Foreground="#4FC3F7"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="14" Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                        <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                                     Width="300" Height="6" Foreground="#4FC3F7" Background="#2A2A2A"/>
                        <TextBlock Text="{Binding TimeElapsed}" FontSize="12" Foreground="#666666" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>

    </Grid>
</UserControl>
